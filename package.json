{
  "name": "EndPointGen",
  "displayName": "EndPointGen",
  "publisher": "KeshavSoft",
  "description": "KeshavSoft AI with voice capture",
  "version": "1.12.1",
  "type": "module",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keshavsoft/keshavai.git"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.initJs",
        "title": "Initiate Node API"
      },
      {
        "command": "extension.createEndpoint",
        "title": "CreateEndpoint"
      },
      {
        "command": "extension.addSubRoute",
        "title": "AddSubRoute"
      },
      {
        "command": "extension.addEndPoint",
        "title": "AddEndPoint"
      },
      {
        "command": "extension.createFullEndpoint",
        "title": "CreateFullEndpoint"
      },
      {
        "command": "extension.forAppJs",
        "title": "Fix App Js"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.initJs",
          "when": "explorerResourceIsFolder",
          "group": "navigation@1"
        },
        {
          "command": "extension.createEndpoint",
          "when": "resourceFilename  == app.js",
          "group": "navigation@2"
        },
        {
          "command": "extension.addSubRoute",
          "when": "resourceFilename  == routes.js",
          "group": "navigation@3"
        },
        {
          "command": "extension.addEndPoint",
          "when": "resourceExtname == .js",
          "group": "navigation@4"
        },
        {
          "command": "extension.createFullEndpoint",
          "when": "resourceExtname == .js",
          "group": "navigation@5"
        }
      ],
      "editor/context": [
        {
          "command": "extension.forAppJs",
          "when": "resourceExtname == .js",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.3",
    "postcss": "^8.5.8"
  }
}